{
  "$schema": "https://design-tokens.org/schema.json",
  "meta": {
    "name": "Neo Mobile Design System",
    "platform": "react-native",
    "colorMode": "dark-only",
    "grid": "4px"
  },
  "colors": {
    "background": {
      "base":     { "value": "#000000", "comment": "Page / screen background" },
      "subtle":   { "value": "#08080F", "comment": "Sidebar, nav surfaces" },
      "elevated": { "value": "#0F0F1A", "comment": "Cards, sheets" },
      "overlay":  { "value": "#13131F", "comment": "Modals, bottom sheets" },
      "muted":    { "value": "#1A1A2E", "comment": "Secondary surfaces" }
    },
    "violet": {
      "950": { "value": "#1A0640" },
      "900": { "value": "#2E0D6E" },
      "800": { "value": "#4C1D95" },
      "700": { "value": "#5B21B6" },
      "600": { "value": "#6D28D9" },
      "500": { "value": "#7C3AED", "comment": "Primary brand / CTA" },
      "400": { "value": "#8B5CF6", "comment": "Hover, interactive" },
      "300": { "value": "#A78BFA", "comment": "Active, accents" },
      "200": { "value": "#C4B5FD" },
      "100": { "value": "#DDD6FE" },
      "50":  { "value": "#EDE9FE" }
    },
    "neutral": {
      "900": { "value": "#16162A" },
      "800": { "value": "#1E1E35" },
      "700": { "value": "#2C2C4A" },
      "600": { "value": "#3D3D5C" },
      "500": { "value": "#55556E" },
      "400": { "value": "#6B6B8A" },
      "300": { "value": "#9898B3" },
      "200": { "value": "#C5C5D8" },
      "100": { "value": "#E2E2EE" },
      "50":  { "value": "#F0F0F8" }
    },
    "semantic": {
      "success":    { "value": "#10B981" },
      "successLt":  { "value": "#34D399" },
      "successBg":  { "value": "#0A2A1F" },
      "warning":    { "value": "#F59E0B" },
      "warningLt":  { "value": "#FCD34D" },
      "warningBg":  { "value": "#2A1F06" },
      "error":      { "value": "#EF4444" },
      "errorLt":    { "value": "#F87171" },
      "errorBg":    { "value": "#2A0A0A" },
      "info":       { "value": "#06B6D4" },
      "infoLt":     { "value": "#22D3EE" },
      "infoBg":     { "value": "#041F26" }
    },
    "text": {
      "primary":   { "value": "#F0F0F8", "comment": "Body copy, headings" },
      "secondary": { "value": "#9898B3", "comment": "Labels, subtext" },
      "tertiary":  { "value": "#6B6B8A", "comment": "Placeholders, hints" },
      "disabled":  { "value": "#3D3D5C" },
      "brand":     { "value": "#A78BFA", "comment": "Brand-colored text" }
    },
    "border": {
      "default": { "value": "#2C2C4A" },
      "subtle":  { "value": "#1E1E35" },
      "strong":  { "value": "#3D3D5C" },
      "brand":   { "value": "#6D28D9" },
      "focus":   { "value": "#8B5CF6" }
    }
  },
  "spacing": {
    "comment": "4px grid. All values are dp numbers (React Native).",
    "0":  { "value": 0 },
    "1":  { "value": 4 },
    "2":  { "value": 8 },
    "3":  { "value": 12 },
    "4":  { "value": 16 },
    "5":  { "value": 20 },
    "6":  { "value": 24 },
    "7":  { "value": 28 },
    "8":  { "value": 32 },
    "10": { "value": 40 },
    "12": { "value": 48 },
    "16": { "value": 64 },
    "20": { "value": 80 },
    "24": { "value": 96 }
  },
  "radii": {
    "none": { "value": 0 },
    "xs":   { "value": 2 },
    "sm":   { "value": 4 },
    "md":   { "value": 8 },
    "lg":   { "value": 12 },
    "xl":   { "value": 16 },
    "2xl":  { "value": 24 },
    "full": { "value": 9999 }
  },
  "typography": {
    "fontFamily": {
      "sans": { "value": "Inter" },
      "mono": { "value": "JetBrainsMono" }
    },
    "fontSize": {
      "caption": { "value": 12 },
      "bodyXs":  { "value": 13 },
      "bodySm":  { "value": 14 },
      "body":    { "value": 16 },
      "bodyLg":  { "value": 18 },
      "h4":      { "value": 20 },
      "h3":      { "value": 24 },
      "h2":      { "value": 30 },
      "h1":      { "value": 36 }
    },
    "fontWeight": {
      "regular":   { "value": "400" },
      "medium":    { "value": "500" },
      "semibold":  { "value": "600" },
      "bold":      { "value": "700" },
      "extrabold": { "value": "800" }
    },
    "lineHeight": {
      "tight":   { "value": 1.25 },
      "snug":    { "value": 1.375 },
      "normal":  { "value": 1.5 },
      "relaxed": { "value": 1.625 }
    }
  },
  "accessibility": {
    "minTouchTarget": {
      "value": 44,
      "comment": "Minimum 44×44 dp per Apple HIG and Material Design"
    },
    "hitSlop": {
      "value": { "top": 8, "bottom": 8, "left": 8, "right": 8 }
    }
  }
}
