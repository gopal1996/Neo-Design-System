{
  "name": "@neo-design-library/mobile",
  "version": "1.1.0",
  "description": "Neo Design System — React Native components",
  "license": "MIT",
  "main": "index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/tokens",
    "src/components",
    "src/index.ts",
    "neo.md",
    "scripts"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --ios",
    "storybook:android": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --android",
    "storybook-generate": "sb-rn-get-stories",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/install-skill.js"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-svg": ">=15.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/slider": "^5.1.2",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@types/react": "~18.3.0",
    "@types/react-native": "^0.73.0",
    "babel-loader": "^8.4.1",
    "babel-plugin-react-docgen-typescript": "^1.5.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-constants": "~17.0.0",
    "expo-font": "~13.0.4",
    "expo-modules-core": "~2.2.3",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-svg": "15.8.0",
    "storybook": "^10.2.16",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@storybook/react-native-theming": "10.2.3"
  }
}
